---
import MainLayout from '../layouts/MainLayout.astro';
---

<!-- Tailwind safelist for dynamic JS class application -->
<!-- bg-yellow-100 text-yellow-800 bg-green-100 text-green-800 bg-red-100 text-red-800 bg-gray-200 text-gray-700 -->

<MainLayout title="WiFi Configuration">
    <div class="max-w-md mx-auto">
        <div class="bg-white rounded-lg shadow p-6">
            <h1 class="text-2xl font-semibold text-gray-800 text-center mb-6">WiFi Configuration</h1>
            <div class="nav mb-4 text-center">
                <a href="/" class="text-blue-600 hover:underline">&larr; Back to Home</a>
            </div>
            <div id="status" class="p-4 rounded mb-4 text-center bg-gray-200 text-gray-700">Access Point Active</div>
            <form id="wifiForm" class="space-y-4">
                <div>
                    <label for="ssid" class="block text-sm font-medium text-gray-600 mb-1">Network Name (SSID)</label>
                    <input type="text" id="ssid" name="ssid" maxlength="31" required placeholder="Enter WiFi network name"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base" />
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-600 mb-1">Password</label>
                    <input type="password" id="password" name="password" maxlength="63" placeholder="Enter WiFi password"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base" />
                </div>
                <button type="submit" id="submitBtn" class="w-full py-3 bg-blue-600 text-white rounded-lg text-base font-medium hover:bg-blue-700 disabled:bg-gray-400 disabled:cursor-not-allowed">
                    Connect
                </button>
            </form>
            <div id="message" class="hidden mt-4"></div>
        </div>
    </div>
</MainLayout>

<script>
    const form = document.getElementById('wifiForm') as HTMLFormElement;
    const statusEl = document.getElementById('status')!;
    const message = document.getElementById('message')!;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    let pollingInterval: ReturnType<typeof setInterval> | null = null;
    let isConnecting = false;

    async function checkStatus() {
        try {
            const resp = await fetch('/status');
            const data = await resp.json();

            if (data.state === 'connecting') {
                statusEl.className = 'p-4 rounded mb-4 text-center bg-yellow-100 text-yellow-800';
                statusEl.innerHTML = '<span class="spinner"></span>Connecting...';
            } else if (data.state === 'connected') {
                statusEl.className = 'p-4 rounded mb-4 text-center bg-green-100 text-green-800';
                statusEl.textContent = 'Connected! IP: ' + data.ip;
                message.className = 'mt-4 p-4 rounded bg-green-100 text-green-800';
                message.textContent = 'WiFi configured successfully.';
                clearInterval(pollingInterval);
            } else if (data.state === 'failed') {
                statusEl.className = 'p-4 rounded mb-4 text-center bg-red-100 text-red-800';
                statusEl.textContent = 'Connection Failed';
                message.className = 'mt-4 p-4 rounded bg-red-100 text-red-800';
                message.textContent = data.message || 'Could not connect to the specified network.';
                submitBtn.disabled = false;
                form.style.display = 'block';
                clearInterval(pollingInterval);
                isConnecting = false;
            }
        } catch (err) {
            console.error('Status check failed:', err);
        }
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (isConnecting) return;

        const ssid = (document.getElementById('ssid') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        if (!ssid || ssid.length > 31) {
            alert('Invalid SSID');
            return;
        }

        isConnecting = true;
        submitBtn.disabled = true;
        form.style.display = 'none';
        statusEl.className = 'p-4 rounded mb-4 text-center bg-yellow-100 text-yellow-800';
        statusEl.innerHTML = '<span class="spinner"></span>Connecting...';
        message.className = 'hidden mt-4';

        try {
            const formData = new URLSearchParams();
            formData.append('ssid', ssid);
            formData.append('password', password);

            const response = await fetch('/configure', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            });

            const result = await response.json();

            if (result.success) {
                pollingInterval = setInterval(checkStatus, 1000);
                checkStatus();
            } else {
                statusEl.className = 'p-4 rounded mb-4 text-center bg-red-100 text-red-800';
                statusEl.textContent = 'Error: ' + (result.message || 'Unknown error');
                submitBtn.disabled = false;
                form.style.display = 'block';
                isConnecting = false;
            }
        } catch (err) {
            statusEl.className = 'p-4 rounded mb-4 text-center bg-red-100 text-red-800';
            statusEl.textContent = 'Request failed';
            submitBtn.disabled = false;
            form.style.display = 'block';
            isConnecting = false;
        }
    });

    checkStatus();
</script>

<style is:global>
    .spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 3px solid rgba(0,0,0,0.1);
        border-radius: 50%;
        border-top-color: #856404;
        animation: spin 1s ease-in-out infinite;
        margin-right: 10px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
</style>
